FRONTEND_HOST=localhost
FRONTEND_PORT=3000
BACKEND_PATH=/backend

# BACKEND_HOST vazio => frontend (React) usa o proxy /backend do proprio host
# (same-origin, caminho relativo). Necessario para subdominio por empresa
# (ex.: teste.localhost). O splash (index.html) monta URL absoluta usando o
# hostname atual + BACKEND_PORT, por isso o port continua definido localmente.
BACKEND_HOST=
BACKEND_PROTOCOL=http
BACKEND_PORT=3000

# Dominio base para derivar o slug da empresa a partir do subdominio.
# Em dev usamos *.localhost (reconhecido automaticamente); em producao,
# defina para o dominio real, ex.: meusite.com.br
APP_BASE_DOMAIN=

EMAIL_ADDRESS=admin@ticketz.host
