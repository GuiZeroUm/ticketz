FRONTEND_HOST=localhost
FRONTEND_PORT=3000
BACKEND_PATH=/backend

EMAIL_ADDRESS=admin@ticketz.host
TZ=America/Sao_Paulo

# Empresa "master" (fallback do branding publico quando nao ha subdominio /
# slug desconhecido). Aponta para a empresa de testes (2), nunca um cliente.
# Se vazio/invalido, o fallback usa a marca neutra generica.
MASTER_COMPANY_ID=2

# Dominio base para derivar o slug da empresa a partir do subdominio do Host.
# Usado pela rota /link-preview (pre-visualizacao de link em redes sociais /
# WhatsApp) para escolher a logo/nome do tenant correto. Deve casar com o
# APP_BASE_DOMAIN do frontend. Em dev usamos *.localhost (reconhecido
# automaticamente); em producao defina o dominio real, ex.: meusite.com.br.
# Vazio => cai na empresa master / marca generica.
APP_BASE_DOMAIN=

BACKEND_URL=http://${FRONTEND_HOST}:${FRONTEND_PORT}${BACKEND_PATH}
FRONTEND_URL=http://${FRONTEND_HOST}:${FRONTEND_PORT}

DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=ticketz
DB_NAME=ticketz
DB_TIMEZONE=-03:00


REDIS_URI=redis://redis:6379
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

USER_LIMIT=10000
CONNECTIONS_LIMIT=100000
CLOSED_SEND_BY_ME=true

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

VERIFY_TOKEN=ticketz
SOCKET_ADMIN=true
